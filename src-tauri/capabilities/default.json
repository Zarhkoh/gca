{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-close",
    "core:event:allow-listen",
    "core:event:allow-emit",
    {
      "identifier": "allow-commands",
      "commands": [
        "get_props",
        "open_url",
        "minimize",
        "close",
        "list_sd",
        "create_sd"
      ]
    }
  ]
}
