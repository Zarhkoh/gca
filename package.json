{
  "name": "GCA",
  "version": "2.0.0",
  "author": {
    "name": "Zarhkoh",
    "email": "GCA@navillus.kim"
  },
  "description": "Generateur de cartes SD pour les enceintes AudioContes Disney",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "test": "echo \"No tests specified\" && exit 0",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac --universal",
    "build:linux": "electron-builder --linux --x64"
  },
  "dependencies": {
    "extract-zip": "^2.0.1",
    "megajs": "^1.3.10"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.gca.app",
    "productName": "GCA",
    "directories": {
      "output": "dist"
    },
    "compression": "maximum",
    "files": [
      "src/**/*",
      "assets/icon.*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "requireAdministrator",
      "icon": "assets/icon.ico"
    },
    "portable": {
      "requestExecutionLevel": "admin"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    }
  }
}
